<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

    <!-- Does the app use advertising or tracking? No. -->
    <key>NSPrivacyTracking</key>
    <false/>

    <!-- No third-party tracking domains -->
    <key>NSPrivacyTrackingDomains</key>
    <array/>

    <!-- Required reason APIs accessed by the app -->
    <key>NSPrivacyAccessedAPITypes</key>
    <array>

        <!-- UserDefaults: store per-user settings, bookmarks, streak, North Star goal -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryUserDefaults</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <!-- CA92.1: app reads and writes data only in its own UserDefaults -->
                <string>CA92.1</string>
            </array>
        </dict>

        <!-- File timestamps: backup file metadata (size, last-modified) shown in BackupView -->
        <dict>
            <key>NSPrivacyAccessedAPIType</key>
            <string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
            <key>NSPrivacyAccessedAPITypeReasons</key>
            <array>
                <!-- C617.1: app only accesses timestamps of files it created in its own container -->
                <string>C617.1</string>
            </array>
        </dict>

    </array>

    <!-- Data collected by the app and how it is used -->
    <key>NSPrivacyCollectedDataTypes</key>
    <array>

        <!-- Email address — used for account creation and sign-in only -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeEmailAddress</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>

        <!-- Journal entries and North Star goal — stored locally, never shared -->
        <dict>
            <key>NSPrivacyCollectedDataType</key>
            <string>NSPrivacyCollectedDataTypeOtherUserContent</string>
            <key>NSPrivacyCollectedDataTypeLinked</key>
            <true/>
            <key>NSPrivacyCollectedDataTypeTracking</key>
            <false/>
            <key>NSPrivacyCollectedDataTypePurposes</key>
            <array>
                <string>NSPrivacyCollectedDataTypePurposeAppFunctionality</string>
            </array>
        </dict>

    </array>

</dict>
</plist>
